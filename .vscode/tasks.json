{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "BUILD_DIR": "build" 
                }
            },
            "command": "cmake -S . -B ${BUILD_DIR} && cmake --build ${BUILD_DIR} -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "CMake build task"
        }
    ]
}
