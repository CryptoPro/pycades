{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "BUILD_DIR": "build"
                }
            },
            "command": "make || make rebuild-library",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "CMake build task"
        },
        {
            "label": "test-setup-root",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "command": "chmod +x ./tests/scripts/setup-root.sh && ./tests/scripts/setup-root.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Setup test root certificate"
        },
        {
            "label": "test-setup-leaf",
            "type": "shell",
            "command": "chmod +x ./tests/scripts/setup-leaf.sh && ./tests/scripts/setup-leaf.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Setup test leaf certificate"
        },
        {
            "label": "test-setup-crl",
            "type": "shell",
            "command": "chmod +x ./tests/scripts/setup-crl.sh && ./tests/scripts/setup-crl.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Setup test crl"
        },
        {
            "label": "launch-setup",
            "dependsOrder": "sequence",
            "dependsOn": [
                "cmake-build",
                "test-setup-root",
                "test-setup-leaf",
                "test-setup-crl"
            ],
            "problemMatcher": []
        }
    ]
}
